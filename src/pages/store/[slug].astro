---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro"; // Or a ProjectLayout if you have one
import createSlug from "../../lib/createSlug";

export async function getStaticPaths() {
  const storeEntries = await getCollection("store");
  return storeEntries.map((entry) => ({
    params: { slug: createSlug(entry.data.title, entry.id) || entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"store">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PostLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.updatedDate}
  heroImage={entry.data.heroImage}
  badge={entry.data.badge}
>
  <Content />
</PostLayout>