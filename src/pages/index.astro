---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1" data-aos="fade-down">Hey there 👋</div>
    <div class="text-5xl font-bold" data-aos="fade-right">I'm Ahmed Zahran Ali</div>
    <div class="text-3xl py-3 font-bold" data-aos="fade-right" data-aos-delay="100">Cloud DevOps & Site Reliability Engineer</div>
    <div class="py-2" data-aos="fade-up" data-aos-delay="200">
      <text class="text-lg">
        Emerging Cloud DevOps Engineer with a Bachelor's degree in Information Technology and hands-on expertise in cloud-native infrastructure. 
        I specialize in orchestrating scalable environments using <b>Terraform, Kubernetes, and Docker</b>. 
        With a strong foundation in AWS serverless architectures and Linux system administration, I engineer zero-trust deployment pipelines 
        and establish proactive observability to optimize cloud operations.
      </text>
    </div>
    <div class="mt-8" data-aos="zoom-in" data-aos-delay="300">
      <a class="btn btn-primary" href="https://www.linkedin.com/in/ahmed-zahran-b0a054393" target="_blank"> Let's Connect</a>
      <a href="/cv" class="btn btn-outline ml-5"> View Resume</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">My Latest Projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="AWS Cloud Resume Challenge"
    img="/post_img.webp"
    desc="A serverless portfolio hosted on AWS using S3, CloudFront, DynamoDB, and Lambda. Deployed via Terraform with GitHub Actions CI/CD."
    url="#"
    badge="AWS & IaC"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Automated Log Archiving Tool"
    img="/post_img.webp"
    desc="Custom Bash utility engineered to automate system log rotation and compression, ensuring storage efficiency for Linux environments."
    url="#"
    badge="Bash & Automation"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Recent Technical Writing</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.id)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>