---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import createSlug from "../lib/createSlug";

const projects = await getCollection("store"); // Or "projects" depending on your folder name
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Technical Projects</div>
  </div>

  {
    projects.map((project) => (
      <>
        <HorizontalCard
          title={project.data.title}
          img={project.data.heroImage}
          desc={project.data.description}
          url={"/projects/" + createSlug(project.data.title, project.id)}
          target="_self"
          badge={project.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }

  <HorizontalCard
    title="Automated Log Archiving Tool"
    img="/post_img.webp"
    desc="A custom Bash utility for compressing and rotating system logs."
    url="#"
  />
</BaseLayout>
